---
---

<footer class="footer" role="contentinfo">
  <div class="container footer__inner">

    <div class="footer__brand">
      <a href="/" class="footer__logo" aria-label="FastMode home">FastMode</a>
      <p class="footer__copy">&copy; 2026 FastMode. All rights reserved.</p>
    </div>

    <nav class="footer__links" aria-label="Footer links">
      <a href="/blog" class="footer__link">Blog</a>
      <span class="footer__divider" aria-hidden="true">&middot;</span>
      <a href="/privacy" class="footer__link">Privacy Policy</a>
      <span class="footer__divider" aria-hidden="true">&middot;</span>
      <a href="/terms" class="footer__link">Terms of Use</a>
    </nav>

  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-2xl);
  }

  .footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-lg);
  }

  /* ── Brand ── */
  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .footer__logo {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: var(--text-lg);
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    transition: opacity var(--transition-fast);
  }

  .footer__logo:hover { opacity: 0.65; }

  .footer__copy {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    line-height: 1;
  }

  /* ── Legal links ── */
  .footer__links {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .footer__link {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    transition: color var(--transition-fast);
  }

  .footer__link:hover { color: var(--color-text-primary); }

  .footer__divider {
    color: var(--color-border);
    font-size: var(--text-sm);
    user-select: none;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .footer__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xl);
    }

    .footer__links { flex-wrap: wrap; }
  }
</style>
