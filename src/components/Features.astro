---
---

<section class="features" aria-labelledby="features-heading">
  <div class="container">
    <h2 class="features__heading" id="features-heading">
      Everything you need.<br />Nothing you don't.
    </h2>

    <div class="features__list">

      <!-- 1. Live Metabolic Phases -->
      <div class="fcard">
        <div class="fcard__text">
          <h3 class="fcard__title">Live Metabolic Phases</h3>
          <p class="fcard__body">
            Your ring timer changes as you keep fasting. Know exactly where you are, always.
          </p>
          <div class="fcard__phases" aria-label="Phases: Fasting, Fat Burn at 12h, Peak Fat Burn at 16h">
            <span class="fcard__phase fcard__phase--muted">Fasting</span>
            <span class="fcard__phase-arrow" aria-hidden="true">→</span>
            <span class="fcard__phase fcard__phase--burn">Fat Burn 12h</span>
            <span class="fcard__phase-arrow" aria-hidden="true">→</span>
            <span class="fcard__phase fcard__phase--peak">Peak Fat Burn 16h</span>
          </div>
        </div>
        <img
          src="/meta-status.png"
          class="fcard__img fcard__img--bar"
          alt="App showing metabolic phases"
          aria-hidden="true"
        />
      </div>

      <!-- 2. Your Personal Goal Date -->
      <div class="fcard fcard--overflow">
        <div class="fcard__text">
          <h3 class="fcard__title">Your Personal Goal Date</h3>
          <p class="fcard__body">
            Enter your stats once. FastMode calculates a realistic goal date. Not "a few months" — an actual date.
          </p>
        </div>
        <img
          src="/personal-plan.png"
          class="fcard__img fcard__img--goal"
          alt="App showing personal goal date"
          aria-hidden="true"
        />
      </div>

      <!-- 3. No Calorie Counting -->
      <div class="fcard fcard--overflow fcard--nocalorie">
        <div class="fcard__text">
          <h3 class="fcard__title">No Calorie Counting</h3>
          <p class="fcard__body">
            Track your eating window, not every gram. It's about when you eat, not what.
          </p>
        </div>
        <div class="fcard__salmon-box" aria-hidden="true">
          <img
            src="/timer.png"
            class="fcard__img fcard__img--nocalorie"
            alt=""
          />
        </div>
      </div>

      <!-- 4. Streak System -->
      <div class="fcard fcard--overflow">
        <div class="fcard__text">
          <h3 class="fcard__title">Streak System</h3>
          <p class="fcard__body">
            Build a daily fasting habit with visual streaks.
          </p>
        </div>
        <img
          src="/streak.png"
          class="fcard__img fcard__img--streak"
          alt="App showing streak calendar"
          aria-hidden="true"
        />
      </div>

      <!-- 5. Streak Freeze -->
      <div class="fcard fcard--overflow">
        <div class="fcard__text">
          <h3 class="fcard__title">Streak Freeze</h3>
          <p class="fcard__body">
            Life happens. Freeze your streak for one day without breaking it. No all-or-nothing pressure.
          </p>
        </div>
        <img
          src="/freeze.png"
          class="fcard__img fcard__img--freeze"
          alt="App showing streak freeze"
          aria-hidden="true"
        />
      </div>

      <!-- 6. Smart Notifications -->
      <div class="fcard">
        <div class="fcard__text">
          <h3 class="fcard__title">Smart Notifications</h3>
          <p class="fcard__body">
            Get notified when you hit Fat Burn, when your eating window is closing, or when your streak is at risk. Contextual, never spammy.
          </p>
        </div>
        <img
          src="/notification.png"
          class="fcard__img fcard__img--notification"
          alt="App notification example"
          aria-hidden="true"
        />
      </div>

      <!-- 7. Weight Tracking & Trends -->
      <div class="fcard fcard--overflow">
        <div class="fcard__text">
          <h3 class="fcard__title">Weight Tracking &amp; Trends</h3>
          <p class="fcard__body">
            Log your weight daily. Watch the trend line move toward your goal. Over time, the data tells a story that the scale alone never could.
          </p>
        </div>
        <img
          src="/chart-card.png"
          class="fcard__img fcard__img--weight"
          alt="App showing weight tracking chart"
          aria-hidden="true"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .features {
    padding: 52px 0 16px;
  }

  .features__heading {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 30px;
    line-height: 1.1;
    letter-spacing: -0.025em;
    text-align: center;
    color: var(--color-text-primary);
    margin-bottom: 44px;
  }

  .features__list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* ── Base card ── */
  .fcard {
    background: white;
    border-radius: 24px;
    padding: 32px 24px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    box-shadow: 0px 24px 20px -14px rgba(0, 0, 0, 0.04);
  }

  .fcard--overflow {
    overflow: hidden;
    position: relative;
  }

  .fcard__text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .fcard__title {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 17px;
    line-height: 1.29;
    letter-spacing: -0.015em;
    text-align: center;
    color: var(--color-text-primary);
    margin-bottom: 8px;
    align-self: stretch;
  }

  .fcard__body {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.6;
    text-align: center;
    color: var(--color-text-secondary);
    align-self: stretch;
  }

  /* ── Metabolic phases pills ── */
  .fcard__phases {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    justify-content: center;
    margin-top: 18px;
    align-self: stretch;
  }

  .fcard__phase {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 13px;
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .fcard__phase--muted  { color: var(--color-text-tertiary); }
  .fcard__phase--burn   { color: var(--color-success); }
  .fcard__phase--peak   { color: var(--color-primary); }

  .fcard__phase-arrow {
    color: var(--color-border);
    font-size: 13px;
    line-height: 1;
  }

  /* ── Images ── */

  /* Full-width bar image (metabolic phases) */
  .fcard__img--bar {
    width: 100%;
    height: 70px;
    object-fit: cover;
    object-position: center;
    border-radius: 8px;
    flex-shrink: 0;
  }

  /* Positioned bottom images — shared */
  .fcard__img--goal,
  .fcard__img--streak,
  .fcard__img--freeze,
  .fcard__img--weight {
    position: absolute;
    left: 50%;
    bottom: -1px;
    transform: translateX(-50%);
    width: 84%;
    max-width: 300px;
    height: auto;
    border-radius: 20px 20px 0 0;
  }

  .fcard--overflow:has(.fcard__img--goal)   { min-height: 320px; }
  .fcard--overflow:has(.fcard__img--streak) { min-height: 360px; }
  .fcard--overflow:has(.fcard__img--freeze) { min-height: 420px; }
  .fcard--overflow:has(.fcard__img--weight) { min-height: 420px; }

  /* No Calorie Counting: salmon box with timer inside */
  .fcard--nocalorie { min-height: 300px; }

  .fcard__salmon-box {
    position: absolute;
    left: 50%;
    bottom: 0;
    transform: translateX(-50%);
    width: 84%;
    max-width: 280px;
    height: 172px;
    background: #FEF5F3;
    border-radius: 20px 20px 0 0;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .fcard__img--nocalorie {
    width: 160px;
    height: auto;
    object-fit: contain;
  }

  /* Notification: full-width image with rounded corners */
  .fcard__img--notification {
    width: 100%;
    height: 74px;
    object-fit: cover;
    object-position: center;
    border-radius: 8px;
    flex-shrink: 0;
  }
</style>
