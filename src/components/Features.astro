---
---

<section class="features section" aria-labelledby="features-heading">
  <div class="container">

    <header class="features__header">
      <p class="features__eyebrow">Features</p>
      <h2 class="features__headline" id="features-heading">
        Everything you need.<br>Nothing you don't.
      </h2>
    </header>

    <ul class="features__grid" role="list">

      <!-- 1. Live Metabolic Phases — featured (2 cols) -->
      <li class="feature feature--metabolic">
        <div class="feature__inner">
          <h3 class="feature__title">Live Metabolic Phases</h3>
          <p class="feature__body">
            Your ring timer changes color as your fast deepens.
            Know exactly where you are, always.
          </p>
          <div class="feature__phases" aria-label="Fasting phases: Fasting, then Fat Burn at 12 hours, then Peak Fat Burn at 16 hours">
            <span class="feature__phase">Fasting</span>
            <span class="feature__phase-arrow" aria-hidden="true">→</span>
            <span class="feature__phase feature__phase--burn">
              Fat Burn
              <span class="feature__phase-time">12h</span>
            </span>
            <span class="feature__phase-arrow" aria-hidden="true">→</span>
            <span class="feature__phase feature__phase--peak">
              Peak Fat Burn
              <span class="feature__phase-time">16h</span>
            </span>
          </div>
        </div>
      </li>

      <!-- 2. Goal Date -->
      <li class="feature feature--goal">
        <div class="feature__inner">
          <h3 class="feature__title">Your Personal Goal Date</h3>
          <p class="feature__body">
            Enter your stats once. FastMode calculates a realistic goal date
            based on your body, pace, and fasting window. Not "a few months" — an actual date.
          </p>
        </div>
      </li>

      <!-- 3. Streak System -->
      <li class="feature feature--streak">
        <div class="feature__inner">
          <h3 class="feature__title">Streak System</h3>
          <p class="feature__body">
            Build a daily fasting habit with visual streaks.
            The longer your streak, the more you want to protect it.
          </p>
          <div class="feature__streak-row" aria-label="Example streak: 6 days completed, 1 upcoming">
            <span class="feature__streak-dot feature__streak-dot--done" title="Day completed"></span>
            <span class="feature__streak-dot feature__streak-dot--done" title="Day completed"></span>
            <span class="feature__streak-dot feature__streak-dot--done" title="Day completed"></span>
            <span class="feature__streak-dot feature__streak-dot--done" title="Day completed"></span>
            <span class="feature__streak-dot feature__streak-dot--done" title="Day completed"></span>
            <span class="feature__streak-dot feature__streak-dot--done" title="Day completed"></span>
            <span class="feature__streak-dot feature__streak-dot--next" title="Today"></span>
          </div>
        </div>
      </li>

      <!-- 4. Streak Freeze -->
      <li class="feature feature--freeze">
        <div class="feature__inner">
          <h3 class="feature__title">Streak Freeze</h3>
          <p class="feature__body">
            Life happens. Freeze your streak for one day without breaking it.
            No all-or-nothing pressure.
          </p>
        </div>
      </li>

      <!-- 5. Smart Notifications -->
      <li class="feature feature--notifications">
        <div class="feature__inner">
          <h3 class="feature__title">Smart Notifications</h3>
          <p class="feature__body">
            Get notified when you hit Fat Burn, when your eating window
            is closing, or when your streak is at risk. Contextual, never spammy.
          </p>
        </div>
      </li>

      <!-- 6. Weight Tracking — Pro (2 cols) -->
      <li class="feature feature--weight">
        <div class="feature__inner">
          <div class="feature__title-row">
            <h3 class="feature__title">Weight Tracking &amp; Trends</h3>
            <span class="feature__pro-badge" aria-label="Pro feature">Pro</span>
          </div>
          <p class="feature__body">
            Log your weight daily. Watch the trend line move toward your goal.
            Over time, the data tells a story that the scale alone never could.
          </p>
        </div>
      </li>

    </ul>
  </div>
</section>

<style>
  .features {
    background-color: var(--color-bg);
  }

  /* ── Header ── */
  .features__header {
    margin-bottom: clamp(var(--space-2xl), 5vw, 64px);
  }

  .features__eyebrow {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-tertiary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--space-md);
  }

  .features__headline {
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.1;
    letter-spacing: -0.025em;
  }

  /* ── Bento grid ── */
  .features__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: auto auto;
    gap: var(--space-md);
    list-style: none;
  }

  /* ── Base card ── */
  .feature {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .feature__inner {
    padding: clamp(var(--space-lg), 2.5vw, var(--space-2xl));
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  /* ── Grid placements ── */
  /* Row 1: [Metabolic 2-cols] [Goal 1-col] [Streak 1-col] */
  .feature--metabolic   { grid-column: span 2; }
  .feature--goal        { grid-column: span 1; }
  .feature--streak      { grid-column: span 1; }

  /* Row 2: [Freeze 1-col] [Notifications 1-col] [Weight 2-cols] */
  .feature--freeze        { grid-column: span 1; }
  .feature--notifications { grid-column: span 1; }
  .feature--weight        { grid-column: span 2; }

  /* ── Featured: Metabolic Phases ── */
  .feature--metabolic {
    background-color: color-mix(in srgb, var(--color-success) 5%, var(--color-surface));
    border-color: color-mix(in srgb, var(--color-success) 20%, var(--color-border));
  }

  /* ── Pro: Weight Tracking ── */
  .feature--weight {
    background-color: color-mix(in srgb, var(--color-primary) 4%, var(--color-surface));
    border-color: color-mix(in srgb, var(--color-primary) 18%, var(--color-border));
  }

  /* ── Typography ── */
  .feature__title {
    font-size: var(--text-xl);
    line-height: 1.25;
    letter-spacing: -0.015em;
  }

  .feature--metabolic .feature__title {
    font-size: clamp(var(--text-xl), 2vw, var(--text-2xl));
  }

  .feature__body {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    flex: 1;
  }

  /* ── Phases progression ── */
  .feature__phases {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-sm) var(--space-md);
    margin-top: auto;
    padding-top: var(--space-md);
  }

  .feature__phase {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: var(--text-sm);
    letter-spacing: -0.01em;
    color: var(--color-text-tertiary);
    display: flex;
    align-items: baseline;
    gap: 5px;
  }

  .feature__phase--burn {
    color: var(--color-success);
  }

  .feature__phase--peak {
    color: var(--color-primary);
  }

  .feature__phase-time {
    font-size: var(--text-xs);
    opacity: 0.75;
    letter-spacing: 0.02em;
  }

  .feature__phase-arrow {
    color: var(--color-border);
    font-size: var(--text-sm);
    font-weight: 400;
  }

  /* ── Streak dots ── */
  .feature__streak-row {
    display: flex;
    gap: 7px;
    margin-top: auto;
    padding-top: var(--space-md);
  }

  .feature__streak-dot {
    width: 22px;
    height: 22px;
    border-radius: var(--radius-full);
    flex-shrink: 0;
  }

  .feature__streak-dot--done {
    background-color: var(--color-primary);
    opacity: 0.9;
  }

  .feature__streak-dot--next {
    border: 2px solid var(--color-primary);
    background-color: transparent;
    opacity: 0.5;
  }

  /* ── Pro badge ── */
  .feature__title-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .feature__pro-badge {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-primary);
    background-color: color-mix(in srgb, var(--color-primary) 12%, transparent);
    padding: 3px 10px;
    border-radius: var(--radius-full);
    flex-shrink: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .features__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .feature--metabolic,
    .feature--weight { grid-column: span 2; }

    .feature--goal,
    .feature--streak,
    .feature--freeze,
    .feature--notifications { grid-column: span 1; }
  }

  @media (max-width: 540px) {
    .features__grid {
      grid-template-columns: 1fr;
      gap: var(--space-sm);
    }

    .feature--metabolic,
    .feature--goal,
    .feature--streak,
    .feature--freeze,
    .feature--notifications,
    .feature--weight { grid-column: span 1; }
  }
</style>
