---

<section class="cta" aria-labelledby="cta-heading">
  <div class="container">
    <div class="cta__card">
      <h2 class="cta__heading" id="cta-heading">
        Start your first fast tonight
      </h2>
      <p class="cta__sub">Available on iPhone and Android.</p>
      <a
        href="https://apps.apple.com/pl/app/fastmode-intermittent-fasting/id6760288550"
        class="cta__btn"
        data-get-app
        aria-label="Download FastMode free"
      >
        Download Free
      </a>
    </div>
  </div>
</section>

<style>
  .cta {
    padding: 0 0 16px;
  }

  .cta__card {
    background: #51C0FD;
    border-radius: 24px;
    padding: 48px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    overflow: hidden;
  }

  .cta__heading {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 38px;
    line-height: 1.08;
    letter-spacing: -0.03em;
    text-align: center;
    color: #0A0A0A;
    margin-bottom: 16px;
  }

  .cta__sub {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    text-align: center;
    color: #0A0A0A;
    margin-bottom: 36px;
  }

  .cta__btn {
    display: inline-flex;
    align-items: center;
    padding: 14px 24px;
    border-radius: 9999px;
    background: #1E1B18;
    color: #F7EFE9;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 15px;
    line-height: 1.2;
    letter-spacing: -0.01em;
    transition: opacity var(--transition-fast), transform var(--transition-fast);
  }

  .cta__btn:hover  { opacity: 0.85; }
  .cta__btn:active { transform: scale(0.97); }

  .cta__btn:focus-visible {
    outline: 2px solid #1E1B18;
    outline-offset: 3px;
  }
</style>
