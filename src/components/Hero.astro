---
---

<section class="hero" aria-label="Hero">
  <div class="container hero__inner">
    <h1 class="hero__heading">
      Turn your overnight fast into a habit worth keeping.
    </h1>
    <div class="hero__card">
      <img
        src="/fastmode-iphone.png"
        class="hero__app-img"
        alt="FastMode app — ring timer showing fasting phase"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: 128px;
    padding-bottom: 24px;
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
  }

  .hero__heading {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 38px;
    line-height: 1.06;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
    text-align: center;
    margin-bottom: 20px;
  }

  .hero__card {
    border-radius: 24px;
    overflow: hidden;
    padding: 32px 0 32px;
    background: url('/patterns-circles.jpg') center / cover no-repeat;
    box-shadow: 0px 24px 20px -14px rgba(0, 0, 0, 0.2);
    display: flex;
    justify-content: center;
    align-items: flex-start;
    width: 100%;
  }

  .hero__app-img {
    width: 87.7%;
    max-width: 342px;
    height: auto;
    display: block;
    flex-shrink: 0;
  }
</style>
